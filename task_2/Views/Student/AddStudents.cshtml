@model Students
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Student Information Form</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="StudentId" class="form-label">Student ID</label>
                                <input asp-for="StudentId" class="form-control" id="studentId" placeholder="Enter student ID">
                                <span asp-validation-for="StudentId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="StudentName" class="form-label">Student Name</label>
                                <input asp-for="StudentName" class="form-control" id="studentName" placeholder="Enter full name">
                                <span asp-validation-for="StudentName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="StudentEmail" class="form-label">Email Address</label>
                                <input asp-for="StudentEmail" class="form-control" id="studentEmail" placeholder="Enter email">
                                <span asp-validation-for="StudentEmail" class="text-danger"></span>

                            </div>

                            <div class="col-md-6">
                                <label asp-for="StudentPhone" class="form-label">Phone Number</label>
                                <input asp-for="StudentPhone"  class="form-control" id="studentPhone"
                                       placeholder="Enter phone number">
                                <span asp-validation-for="StudentPhone" class="text-danger"></span>

                            </div>

                            <div class="col-md-6">
                                <label asp-for="StudentCGPA"  class="form-label">CGPA</label>
                                <input asp-for="StudentCGPA"  step="0.01" min="0" max="4" class="form-control" id="studentCgpa
                                       placeholder="Enter CGPA">
                                <span asp-validation-for="StudentCGPA" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save</button>
                            <button type="reset" class="btn btn-outline-secondary">Reset</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
