@model List<StudentInfo>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Student ID</th>
            <th>Student Name</th>
            <th>Email Address</th>
            <th>Phone Number</th>
            <th>CGPA</th>
        </tr>
    </thead>
    @{foreach(var student in Model){
        <tr>
            <td>@student.Sid</td>
            <td>@student.Name</td>
            <td>@student.Email</td>
            <td>@student.Phone</td>
            <td>@student.Cgpa</td>
        </tr>
        }
        }
</table>