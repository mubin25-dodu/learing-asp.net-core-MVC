@model List<Students>
<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Student ID</th>
            <th>Student Name</th>
            <th>Email Address</th>
            <th>Phone Number</th>
            <th>CGPA</th>
        </tr>
    </thead>
    @{foreach(var student in Model){
        <tr>
            <td>@student.StudentId</td>
            <td>@student.StudentName</td>
            <td>@student.StudentEmail</td>
            <td>@student.StudentPhone</td>
            <td>@student.StudentCGPA</td>
        </tr>
        }
        }
</table>